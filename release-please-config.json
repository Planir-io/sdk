{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": true,
  "tag-separator": "-",
  "separate-pull-requests": true,
  "packages": {
    "ts": {
      "release-type": "node",
      "component": "ts",
      "versioning": "prerelease",
      "prerelease": true,
      "prerelease-type": "beta"
    },
    "python": {
      "release-type": "python",
      "component": "python",
      "package-name": "planir",
      "versioning": "prerelease",
      "prerelease": true,
      "prerelease-type": "beta"
    }
  }
}
